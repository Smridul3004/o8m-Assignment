# ===========================================
# o8m Labs — Environment Variables
# Copy this to .env and fill in real values
# ===========================================

# --- Databases ---
POSTGRES_USER=o8m_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=o8m_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

MONGO_URI=mongodb://mongo:27017/o8m
MONGO_HOST=mongo
MONGO_PORT=27017

REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BROKER=kafka:9092

# --- JWT ---
JWT_SECRET=change_me_to_a_strong_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Agora (server-side only — NEVER expose to client) ---
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# --- Firebase Cloud Messaging ---
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Platform Business Rules ---
PLATFORM_CUT_PERCENT=30
CALL_TIMEOUT_SECONDS=30
RECONNECT_WINDOW_SECONDS=10
MIN_CALL_DURATION_MINUTES=1

# --- Service Ports ---
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
DISCOVERY_SERVICE_PORT=3003
CHAT_SERVICE_PORT=3004
CALL_SERVICE_PORT=3005
BILLING_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
